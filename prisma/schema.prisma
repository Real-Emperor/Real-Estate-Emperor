generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  nameBn      String?
  nameUr      String?
  phone       String?
  email       String?
  address     String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  properties  Property[]
  tenants     Tenant[]
  expenses    Expense[]
  maintenance Maintenance[]
  users       User[]
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  nameAr      String?
  nameBn      String?
  nameUr      String?
  role        String   @default("owner") // owner, admin, staff
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
}

model Property {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  nameAr      String?
  nameBn      String?
  nameUr      String?
  type        String   // apartment, villa, office, shop, studio, mixed_use
  address     String?
  totalUnits  Int      @default(1)
  floors      Int      @default(1)
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  tenants     Tenant[]
}

model Tenant {
  id                String   @id @default(cuid())
  companyId         String
  company           Company  @relation(fields: [companyId], references: [id])
  propertyId        String
  property          Property @relation(fields: [propertyId], references: [id])
  name              String
  nameAr            String?
  nameBn            String?
  nameUr            String?
  phone             String
  whatsapp          String?
  email             String?
  emiratesId        String?
  nationality       String?
  employer          String?
  emergencyContact  String?
  unitNumber        String?
  unitType          String?  // studio, 1bedroom, 2bedroom, 3bedroom, shop, office
  floor             Int?
  sizeSqft          Float?
  rentAmount        Float
  municipalityFee   Float?   // 5% of monthly rent
  securityDeposit   Float?
  paymentMethod     String?  // cash, bank_transfer, cheque
  leaseStart        DateTime?
  leaseEnd          DateTime?
  contractDuration  Int?     // in months
  renewalStatus     String?  // active, expiring_soon, expired, renewed
  newRent           Float?
  status            String   @default("active") // active, inactive, evicted, notice
  latePaymentCount  Int      @default(0)
  tenantScore       Int      @default(100) // 0-100, starts at 100, decreases with late payments
  notes             String?
  createdAt         DateTime @default(now())
  payments          Payment[]
}

model Payment {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount        Float
  date          DateTime
  month         Int
  year          Int
  method        String?
  reference     String?
  receiptNumber String?
  notes         String?
  isLate        Boolean  @default(false)
  daysLate      Int      @default(0)
  createdAt     DateTime @default(now())
}

model Expense {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  category      String
  description   String
  amount        Float
  date          DateTime
  vendor        String?
  invoiceNumber String?
  recurring     Boolean  @default(false)
  building      String?
  createdAt     DateTime @default(now())
}

model Maintenance {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  propertyId    String?
  title         String
  description   String
  category      String?  // AC, Plumbing, Electrical, Lock/Door, Painting, Structural, Other
  vendor        String?
  priority      String   @default("medium") // urgent, high, medium, low
  status        String   @default("pending") // pending, in-progress, completed
  estimatedCost Float?
  actualCost    Float?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Company {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  phone       String?
  email       String?
  address     String?
  logoUrl     String?
  createdAt   DateTime @default(now())
  properties  Property[]
  tenants     Tenant[]
  expenses    Expense[]
  maintenance Maintenance[]
  users       User[]
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  role        String   @default("owner")
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
}

model Property {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String
  nameAr      String?
  type        String
  address     String?
  totalUnits  Int      @default(1)
  createdAt   DateTime @default(now())
  tenants     Tenant[]
}

model Tenant {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id])
  name          String
  nameAr        String?
  phone         String
  email         String?
  unitNumber    String?
  rentAmount    Float
  leaseStart    DateTime?
  leaseEnd      DateTime?
  status        String   @default("active")
  createdAt     DateTime @default(now())
  payments      Payment[]
}

model Payment {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  amount        Float
  date          DateTime
  month         Int
  year          Int
  method        String?
  reference     String?
  notes         String?
  createdAt     DateTime @default(now())
}

model Expense {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  category      String
  description   String
  amount        Float
  date          DateTime
  createdAt     DateTime @default(now())
}

model Maintenance {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  propertyId    String?
  title         String
  description   String
  priority      String   @default("medium")
  status        String   @default("pending")
  cost          Float?
  createdAt     DateTime @default(now())
  completedAt   DateTime?
}

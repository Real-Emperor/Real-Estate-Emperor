generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                 String   @id @default(cuid())
  name               String
  nameAr             String?
  nameBn             String?
  nameUr             String?
  phone              String?
  email              String?
  address            String?
  logoUrl            String?
  plan               String   @default("free")
  maxProperties      Int      @default(10)
  maxUsers           Int      @default(5)
  stripeCustomerId   String?
  subscriptionStatus String?
  subscriptionEnd    DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  properties    Property[]
  tenants       Tenant[]
  expenses      Expense[]
  maintenance   Maintenance[]
  users         User[]
  backupRecords BackupRecord[]
  receipts      Receipt[]
  notifications Notification[]

  @@map("companies")
}

model User {
  id                   String         @id @default(cuid())
  email                String         @unique
  password             String
  name                 String
  nameAr               String?
  nameBn               String?
  nameUr               String?
  role                 String         @default("staff") // owner, admin, staff
  mustChangePassword   Boolean        @default(false)
  passwordChangedAt    DateTime?
  companyId            String
  company              Company        @relation(fields: [companyId], references: [id])
  isActive             Boolean        @default(true)
  twoFactorSecret      String?
  twoFactorEnabled     Boolean        @default(false)
  twoFactorBackupCodes String?
  deletedAt            DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  resetRequests        ResetRequest[] @relation("ResolvedBy")
  auditLogs            AuditLog[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model Property {
  id          String     @id @default(cuid())
  companyId   String
  company     Company    @relation(fields: [companyId], references: [id])
  name        String
  nameAr      String?
  nameBn      String?
  nameUr      String?
  type        String     // apartment, villa, office, shop, studio, mixed_use
  address     String?
  totalUnits  Int        @default(1)
  floors      Int        @default(1)
  archived    Boolean    @default(false)
  deletedAt   DateTime?  // soft delete
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenants     Tenant[]
  maintenance Maintenance[]

  @@index([companyId])
  @@index([archived])
  @@map("properties")
}

model Tenant {
  id               String   @id @default(cuid())
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  propertyId       String
  property         Property @relation(fields: [propertyId], references: [id])
  name             String
  nameAr           String?
  nameBn           String?
  nameUr           String?
  phone            String
  whatsapp         String?
  email            String?
  emiratesId       String?
  nationality      String?
  employer         String?
  emergencyContact String?
  unitNumber       String?
  unitType         String?    // studio, 1bedroom, 2bedroom, 3bedroom, shop, office
  floor            Int?
  sizeSqft         Float?
  rentAmount       Float
  municipalityFee  Float?
  securityDeposit  Float?
  paymentMethod    String?    // cash, bank_transfer, cheque
  leaseStart       DateTime?
  leaseEnd         DateTime?
  contractDuration Int?       // in months
  renewalStatus    String?    // active, expiring_soon, expired, renewed
  newRent          Float?
  status           String   @default("active") // active, inactive, evicted, notice
  latePaymentCount Int      @default(0)
  tenantScore      Int      @default(100)
  notes            String?
  deletedAt        DateTime? // soft delete
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  payments         Payment[]
  receipts         Receipt[]

  @@index([companyId])
  @@index([propertyId])
  @@index([status])
  @@map("tenants")
}

model Payment {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount        Float
  date          DateTime
  month         Int
  year          Int
  method        String?
  reference     String?
  receiptNumber String?
  notes         String?
  isLate        Boolean  @default(false)
  daysLate      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([month, year])
  @@index([date])
  @@map("payments")
}

model Expense {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  category      String
  description   String
  amount        Float
  date          DateTime
  vendor        String?
  invoiceNumber String?
  recurring     Boolean  @default(false)
  building      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime? // soft delete

  @@index([companyId])
  @@index([category])
  @@index([date])
  @@map("expenses")
}

model Maintenance {
  id            String    @id @default(cuid())
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  propertyId    String?
  property      Property? @relation(fields: [propertyId], references: [id])
  title         String
  description   String
  category      String?
  vendor        String?
  priority      String    @default("medium") // urgent, high, medium, low
  status        String    @default("pending") // pending, in-progress, completed
  estimatedCost Float?
  actualCost    Float?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // soft delete

  @@index([companyId])
  @@index([status])
  @@index([propertyId])
  @@map("maintenance")
}

model ResetRequest {
  id         String   @id @default(cuid())
  email      String
  name       String
  message    String
  status     String   @default("pending") // pending, resolved, dismissed
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  resolvedBy String?
  resolver   User?    @relation("ResolvedBy", fields: [resolvedBy], references: [id])
  updatedAt  DateTime @updatedAt
  companyId  String?

  @@index([status])
  @@map("reset_requests")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT
  entity    String   // Property, Tenant, Payment, Expense, Maintenance, User
  entityId  String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  details   String?  // JSON string with before/after snapshots
  companyId String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([companyId])
  @@map("audit_logs")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model RateLimitEntry {
  id         String    @id @default(cuid())
  identifier String    @unique
  count      Int       @default(0)
  resetAt    DateTime?
  lockedUntil DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([lockedUntil])
  @@map("rate_limit_entries")
}

model BackupRecord {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  type        String
  size        Int
  recordCount Int
  status      String
  error       String?
  createdAt   DateTime @default(now())

  @@index([companyId])
  @@index([createdAt])
  @@map("backup_records")
}

model Receipt {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  paymentId     String?
  receiptNumber String
  amount        Float
  date          DateTime
  month         Int
  year          Int
  description   String?
  createdBy     String
  createdAt     DateTime @default(now())

  @@index([companyId])
  @@index([tenantId])
  @@index([receiptNumber])
  @@map("receipts")
}

model Notification {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  userId    String?
  type      String
  title     String
  message   String
  data      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}
